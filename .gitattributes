# Keep Oxfmt's LF output stable on Windows even when core.autocrlf is enabled.
* text=auto eol=lf

# The generated bundles are compared byte-for-byte by the CI
# staleness check. Treat it as binary so git never rewrites its line endings.
mcp-server/dist/index.js -text
mcp-server/dist/mcp-app.html -text
