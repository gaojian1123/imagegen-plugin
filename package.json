{
  "name": "imagegen",
  "version": "0.1.0",
  "private": true,
  "description": "Generate and edit images with a gpt-image-2 Azure OpenAI deployment.",
  "type": "module",
  "scripts": {
    "build": "vp build && vp pack",
    "test": "vp test",
    "typecheck": "tsc",
    "smoke": "node scripts/smoke.mjs",
    "preview": "node scripts/preview-client.mjs",
    "dev:host": "vp build && node scripts/dev-host.mjs",
    "dev:check": "node scripts/dev-check.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "openai": "^6.45.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "12.0.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24"
  }
}
