{
  "name": "imagegen",
  "version": "0.1.0",
  "description": "Generate and edit images with a gpt-image-2 Azure OpenAI deployment.",
  "type": "module",
  "private": true,
  "scripts": {
    "build:ui": "vite build",
    "build": "npm run build:ui && esbuild mcp-server/index.ts --bundle --platform=node --format=esm --outfile=mcp-server/dist/index.js --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "test": "node --test mcp-server/client.test.ts mcp-server/preview.test.ts mcp-server/server.test.ts mcp-server/store.test.ts",
    "typecheck": "tsc",
    "smoke": "node scripts/smoke.mjs",
    "preview": "node scripts/preview-client.mjs",
    "dev:host": "npm run build:ui && node scripts/dev-host.mjs",
    "dev:check": "node scripts/dev-check.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "openai": "^6.45.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.0",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
