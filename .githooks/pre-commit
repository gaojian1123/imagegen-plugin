#!/usr/bin/env sh
# Auto-rebuild the committed bundle when the MCP server source changes, so
# mcp-server/dist/* can never drift from mcp-server/*.ts in a commit.
# Enable once with:  git config core.hooksPath .githooks
# Uses `node --run` (not `npm run`) so it reuses the package.json build script
# without needing a shell (bash) on PATH inside the git hook environment.
if git diff --cached --name-only | grep -q '^mcp-server/.*\.ts$'; then
  echo "[pre-commit] mcp-server source changed — rebuilding bundle..."
  node --run build || { echo "[pre-commit] build failed"; exit 1; }
  git add mcp-server/dist
fi
